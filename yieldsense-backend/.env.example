# Copy this file to .env and fill in real values. Never commit .env itself.

# --- Database ---
DATABASE_URL=postgresql://yieldsense_user:changeme@localhost:5432/yieldsense_db

# --- Auth ---
# Generate a real secret with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_this_with_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# --- External APIs (Milestone 1, Task 3 integration point) ---
WEATHER_API_KEY=your_meteorological_api_key_here
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5
